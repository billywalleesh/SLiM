//exercise 1
1000 late() {
	seg_mut = sample(sim.mutations, 1);
	target = seg_mut;
	defineConstant("SWEEP", target);
	SWEEP.setMutationType(m2);
	SWEEP.setSelectionCoeff(0.1);
	defineConstant("CHECKPOINT", tempdir() + "slim_" + SIM_ID + ".txt");
	sim.outputFull(CHECKPOINT, binary=T, substitutions=T);
}


1000:100000 late() {
	if (!SWEEP.isSegregating)
	{
		if (SWEEP.isFixed)
		{
			cat(SIM_ID + ": FIXED\n");
			sim.simulationFinished();
		}
		else
		{
			cat(SIM_ID + ": LOST - RESTARTING\n");
			sim.readFromPopulationFile(CHECKPOINT);
			defineConstant("SWEEP", sim.mutationsOfType(m2));
		}
	}
	else
	{
		freq = sim.mutationFrequencies(NULL, SWEEP);
		catn(sim.cycle + ": " + freq);
	}
}


100000 late() {
	catn("TIME EXPIRED");
	sim.simulationFinished();
}

