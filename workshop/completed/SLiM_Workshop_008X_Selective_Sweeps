// set up a simple neutral simulation
initialize() {
	//try to always define constatnts in the initialize area (count, size, etc) capital letters 			are global
	defineConstant("SIM_ID", getSeed());
	initializeMutationRate(1e-7);
	initializeMutationType("m1", 0.5, "f", 0.0);
	// introduced mutation 1.0 = dominance coefficient 0.5 = selection coefficient (0.5 = strongly 	beneficial. (1.0 = fully dominant).	
	initializeMutationType("m2", 1.0, "f", 0.01);
	initializeGenomicElementType("g1", m1, 1.0);
	initializeGenomicElement(g1, 0, 99999);
	initializeRecombinationRate(1e-8);
}
// create a population of 500 individuals
1 early() {
	sim.addSubpop("p1", 500);
}
