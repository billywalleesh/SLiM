/// evolutionary rescue model with multiple subpopulations
/// nonWF QTL adaptation model with environmental change


initialize()
{
	// use nonWF model
	initializeSLiMModelType("nonWF");
	// demographic parameters
	defineConstant("Ne", 250);     // effective population per subpopulation
	defineConstant("N", 8);        // number of subpopulations
	defineConstant("m", 0.01);     // migration rate
	//defineConstant("e", 0.1);      // extinction rate 
	
	// automatically create vector: c(1,2,3,4,5...)
	defineConstant("opt", asFloat(1:N));
	
	// optional shifted vector: c(11,12,13,14,15...)
	defineConstant("opt_delta", asFloat((1:N) + 10));
	
	// timing of environmental shift
	defineConstant("Tdelta", 10000);
	
	// QTL mutations
	// effects drawn from N(0,1)
	initializeMutationType("m1", 0.5, "n", 0.0, 1.0);
	
	// optional neutral mutation type
	//initializeMutationType("m0", 0.5, "f", 0.0);
	
	// genomic structure
	initializeGenomicElementType("g1", m1, 1.0);
	initializeGenomicElement(g1, 0, 99999);
	
	/** alternative mixed genome structure */
	/*
	initializeGenomicElementType("g2", c(m0, m1), c(0.9, 0.1));
	initializeGenomicElement(g1, 0, 20000);
	initializeGenomicElement(g2, 20001, 30000);
	initializeGenomicElement(g1, 30001, 99999);
	*/
	
	// mutation + recombination rates
	initializeMutationRate(1e-7);
	initializeRecombinationRate(1e-8);
}

/// create subpopulations

1 early()
{
	// create subpopulations
	for (i in 1:N)
		sim.addSubpop("p" + i, Ne);
	
	// assign optimum to each subpopulation
	for (i in 1:N)
	{
		subpop = sim.subpopulations[i - 1];
		
		subpop.setValue("optimum", opt[i - 1]);
	}
}

1 early()
{
	writeFile(
		"population_log.csv",
		"tick,pop_id,N,optimum,phenotype_mean,phenotype_sd,phenotype_min,phenotype_max,allelic_richness,phenotype_lag,adaptive_fitness,extinct",
		append=F
		);
}

/// reproduction
reproduction()
{
	if (subpop.individualCount == 0)
		return;
	//keeping reproduction within pops seperate 
	subpop.addCrossed(individual, subpop.sampleIndividuals(1));
}

//forward migration
early()
{
	if (N > 1){
		for (i in 0:(N-2))
		{
		source = sim.subpopulations[i];
		dest   = sim.subpopulations[i+1];
			
			nMig = asInteger(source.individualCount * m);
			
			if (nMig > 0)
			{migrants = sample(source.individuals, nMig);
				
				dest.takeMigrants(migrants);}
		}
	}
}

//backward migration
early()
{
    if (N > 1){
    for (i in 1:(N-1))
    {
        source = sim.subpopulations[i];
        dest = sim.subpopulations[i-1];

        nMigrants =
            asInteger(source.individualCount * m);

        if (nMigrants > 0)
        {
            migrants =
                sample(source.individuals,
                       nMigrants);

            dest.takeMigrants(migrants);}
        }
    }
}


/// phenotype + fitness calculation
early()
{
	// environmental change
	if (sim.cycle == Tdelta)
	{
		for (i in 1:N)
		{
			subpop = sim.subpopulations[i - 1];
			subpop.setValue("optimum", opt_delta[i - 1]);
		}
	}
	
	//calculate fitness selection
	for (pop in sim.subpopulations)
	{
		//get current optimum
		optimum = pop.getValue("optimum");
		
		// get individuals according to population
		inds = pop.individuals;
		
		// phenotype = additive sum of QTL effects
		phenotypes = inds.sumOfMutationsOfType(m1);
		
		// distance from optimum
		deviations = optimum - phenotypes;
		
		// normalize Gaussian fitness function
		fitnessFunctionMax = dnorm(0.0, 0.0, 5.0);
		
		// calculate degree of adaptation
		adaptation = dnorm(deviations, 0.0, 5.0) / fitnessFunctionMax;
		
		// convert adaptation into fitness
		//
		// perfectly adapted individual:
		// fitnessScaling = 1.0
		//
		// maladapted individual:
		// fitnessScaling approaches 0.1
		inds.fitnessScaling = 0.1 + adaptation * 0.9;
		
		// store phenotype values for output
		inds.tagF = phenotypes;
		
		// density-dependent population regulation
		//
		// low-density populations receive a fitness boost
		// capped at 1.5 to avoid unrealistic growth
		pop.fitnessScaling =
			min(Ne / pop.individualCount, 1.5);
	}
}

/// mutation effects

// QTL mutations are directly neutral
// fitness effects occur indirectly through phenotype
mutationEffect(m1) {return 1.0;}

/// output + extinction checks
late()
{
	for (pop in sim.subpopulations)
	{
		optimum = pop.getValue("optimum");
		
		// extinct population
		if (pop.individualCount == 0)
		{
			line =
				sim.cycle + "," +
				pop.id + "," +
				"0," +
				optimum + "," +
				"NA,NA,NA,NA," +
				"0," +
				"NA," +
				"0," +
				"1";
			
			writeFile(
				"population_log.csv",
				line,
				append=T
				);
			
			catn(
				sim.cycle +
				" | Pop " +
				pop.id +
				" | EXTINCT"
				);
		}
		
		// extant population
		else
		{
			phenotypes = pop.individuals.tagF;
			
			phenotype_mean = mean(phenotypes);
			
			phenotype_sd =
				(size(phenotypes) > 1) ?
				sd(phenotypes) else 0.0;
			
			phenotype_min = min(phenotypes);
			phenotype_max = max(phenotypes);
			
			phenotype_lag =
				optimum - phenotype_mean;
			
			muts =
				unique(pop.haplosomes.mutationsOfType(m1));
			
			if (size(muts) > 0)
			{
				freqs =
					sim.mutationFrequencies(pop, muts);
				
				allelic_richness =
					sum(freqs > 0.0 & freqs < 1.0);
			}
			else
			{
				allelic_richness = 0;
			}
			
			deviations =
				optimum - phenotypes;
			
			fitnessFunctionMax =
				dnorm(0.0, 0.0, 5.0);
			
			adaptation =
				dnorm(deviations, 0.0, 5.0) /
				fitnessFunctionMax;
			
			adaptive_fitness =
				mean(adaptation);
			
			line =
				sim.cycle + "," +
				pop.id + "," +
				pop.individualCount + "," +
				optimum + "," +
				phenotype_mean + "," +
				phenotype_sd + "," +
				phenotype_min + "," +
				phenotype_max + "," +
				allelic_richness + "," +
				phenotype_lag + "," +
				adaptive_fitness + "," +
				"0";
			
			writeFile(
				"population_log.csv",
				line,
				append=T
				);
			
			catn(
				sim.cycle +
				" | Pop " + pop.id +
				" | N=" + pop.individualCount +
				" | Mean phenotype=" +
				phenotype_mean +
				" | Mean fitness=" +
				adaptive_fitness
				);
		}
	}
	
	//SLimgui extinction check
	extinctPops =
		sum(sim.subpopulations.individualCount == 0);
	
	catn(
		"Extinct populations: " +
		extinctPops
		);
	
	if (sum(sim.subpopulations.individualCount) == 0)
	{
		catn(
			"GLOBAL EXTINCTION at cycle " +
			sim.cycle
			);
		
		sim.simulationFinished();
	}
}

/// end simulation
20000 late(){sim.simulationFinished();}