// Set ageing, migration and survival 
early() {
	K=5000; // maxmimal capacity per sub-pop (5000 individuals)
	
	inds = sim.subpopulations.individuals; // get all the individuals
	
	// AGE MORTALITY
	// non-overlapping generations; kill off the parental generation
	ages = inds.age; // get age of all individuals
	inds[ages > 0].fitnessScaling = 0.0; // if old individuals -> kill them
	inds = inds[ages == 0]; // keep only juveniles
	
	subpops = sim.subpopulations;
	
	// Each source population sends migrants to each destination population.
	// sourcePop and destPop are matrix positions; sourceSubpop and destSubpop are SLiM objects.
	// pops are named p0, p1, p2...; matrix positions are 0, 1, 2...
	for (sourcePop in 0:(numPops - 1))
	{
		sourceSubpop = subpops[sourcePop];
		
		for (destPop in 0:(numPops - 1))
		{
			destSubpop = subpops[destPop];
			
			if (sourcePop == destPop)
				next;
			
			// look up migration probability in the migration matrix
			migrationRate = M[sourcePop, destPop];
			
			// migrant individuals are not sampled again in the same generation
			potentialMigrants = sourceSubpop.individuals[sourceSubpop.individuals.migrant == F];
			
			// draw how many individuals migrate from this source population to this destination population
			numMigrants = rbinom(1, potentialMigrants.size(), migrationRate);
			
			if (numMigrants == 0)
				next;
			
			// sample which specific individuals will migrate and send them to their destination
			migrants = sample(potentialMigrants, numMigrants);
			destSubpop.takeMigrants(migrants);
		}
	}
	
	// post-migration density-dependent fitness for each subpop
	for (subpop in sim.subpopulations)
	{
		juvenileCount = sum(subpop.individuals.age == 0); // after the migration: count how many juveniles are there
		subpop.fitnessScaling = K / juvenileCount; // set fitness of juveniles based on the maximal capacity of the sub-population (K)
	}
}

///// FIRST PHASE: nothing happens
// In the first 2000 generations: nothing happens --> all mutations build up as neutral, there is no selection in any population 



///// SECOND AND THIRD PHASES: local adaptation, then climate shift
// From generation 2000 to 3999: populations adapt to climate1.
// From generation 4000 to 6000: populations experience climate2.
2000:6000 fitnessEffect() {
	climates = (sim.cycle < Tdelta ? climate1 else climate2);
	climate = climates[subpop.id]; // p0 = climate[0], p1 = climate[1], p2 = climate[2]...
	
	phenotype = asFloat(individual.countOfMutationsOfType(m2)); // the phenotype (optimal climate) of an individual is the sum of the m2 mutations in their genome. For ex. an individual is adapted to climate = 2 if they have 2 m2 mutations. 
	
	fitness = 1 - ((phenotype-climate)^2)*0.05; // fitness defined by a quadratic function. If phenotype = climate -> fitness is 1, otherwise it declines. The shaping parameter (here 0.05) determines how much fitness declines as phenotypes diverges from the climate
	fitness[fitness<0] = 0; // if fitness is negative --> set to 0
	return fitness;
}


