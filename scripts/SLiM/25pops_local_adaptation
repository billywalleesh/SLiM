initialize() {
	initializeSLiMModelType("nonWF"); // set non-WF model
	
	defineConstant("inputDirectory", "C:/Users/WilliamWallisch/msc_workspace/SLiM/input/");
	// Migration CSV must be square: one row and one column per population
	defineConstant("migrationFile", inputDirectory + "migration_matrix_v1.6.csv");
	// Climate CSV must have one column for each population in the migration CSV
	defineConstant("climateFile", inputDirectory + "climate_matrix_v1.6.csv");
	
	migrationTable = readCSV(migrationFile, colNames=F);
	climateTable = readCSV(climateFile, colNames=F);
	
	migrationInput = migrationTable.asMatrix();
	climateInput = climateTable.asMatrix();
	
	defineConstant("numPops", nrow(migrationInput)); // number of subpopulations
	defineConstant("M", migrationInput); // migration rates: rows are source pops, columns are destination pops
	defineConstant("gridSize", 5); // v1.6 uses a 5 by 5 population grid
	
	defineConstant("Tdelta", 4000); // climate shift generation
	defineConstant("climate1", drop(climateInput[0,])); // baseline climate gradient: p0, p1, p2...
	defineConstant("climate2", drop(climateInput[1,])); // shifted climate gradient: p0, p1, p2...
	
	initializeMutationRate(1e-7); // set standard mutation rate
	initializeRecombinationRate(1e-8); // set standard recombination rate
	initializeMutationType("m1", 0.5, "f", 0.0); // set neutral mutations
	initializeMutationType("m2", 0.5, "f", 0.0); // set mutations that will have an effect (defined here as neutral, but we'll add a phenotypic effect below). 
	m2.color = "red"; // will be displayed in red in the output
	initializeGenomicElementType("g1", c(m1,m2), c(0.99,0.01)); // set relative frequency: m2 is 1% of all mutations
	initializeGenomicElement(g1, 0, 99999); // set genome size
}

// Set reproduction behavior: every individual gets a number of offspring from a poisson distriubtion of mean R. 
reproduction() {
	R = 1.01; // on average every individual 1.01 offspring
	
	// individuals reproduce locally, without dispersal
	litterSize = rpois(1, R);
	
	for (i in seqLen(litterSize))
	{
		// generate each offspring with an independently drawn mate
		mate = subpop.sampleIndividuals(1, exclude=individual);
		if (mate.size())
			subpop.addCrossed(individual, mate);
	}
}

