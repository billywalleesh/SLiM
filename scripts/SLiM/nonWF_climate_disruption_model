//building on v2 by adding 4 popultaions with migration rates 
//initialize the model 
//set effective population size to 500
// opt 1 and 2 represent the phenotypic optimum before and after environmental change
//m1 mutations create a QTL which is drawn from a normal distribution centered on 0.0 with a standard deviation of 1.0.
//tdelta is when the disturbance will occur
initialize()
{
	initializeSLiMModelType("nonWF");
	defineConstant("Ne", 500); // effective population size per subpop
	defineConstant("N", 3); // number of subpopulations
	defineConstant("m", 0.01); // migration rate
	defineConstant("e", 0.1); // subpopulation extinction rate
	defineConstant("opt1", 0.0);
	defineConstant("opt2", 10.0);
	defineConstant("Tdelta", 10000);
	initializeMutationType("m1", 0.5, "n", 0.0, 1.0); // QTL
	initializeGenomicElementType("g1", m1, 1.0);
	initializeGenomicElement(g1, 0, 99999);
	initializeMutationRate(1e-7);
	initializeRecombinationRate(1e-8);
}

//add 4 populations with 500 individuals
1 early()
{
	for (i in 1:N)
		sim.addSubpop(i, 500);
}

//add simple hermaphrodidic reproduction
reproduction ()
{
	for (pop in sim.subpopulations)
		if (pop.individualCount == 0)
			return;
		
		else
			pop.addCrossed(individual, pop.sampleIndividuals(1));
}

