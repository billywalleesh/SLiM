early()
{
	// QTL-based fitness
	inds = sim.subpopulations.individuals;
	
	//phenotypes as the sum of the effects of all QTLs possessed by the individual
	phenotypes = inds.sumOfMutationsOfType(m1);
	
	//which phenotypic optimum is in effect
	optimum = (sim.cycle < Tdelta) ? opt1 else opt2;
	
	//calculate the deviation of each individual from the optimum
	deviations = optimum - phenotypes;
	
	//calculate the degree of adaptation of each individual using a normal dist to show deviation from optimum divided by max fitness if they are better or worse abdapted based on phenotype
	//fitnessFunctionMax normalizes the adaptation values to the range (0,1)
	fitnessFunctionMax = dnorm(0.0, 0.0, 5.0);
	adaptation = dnorm(deviations, 0.0, 5.0) / fitnessFunctionMax;
	
	//perfectly adapted individual will have an adaptation value of 1.0
	//0.1 = “floor”
	inds.fitnessScaling = 0.1 + adaptation * 0.9;
	inds.tagF = phenotypes; // just for output below
	
	// density-dependence with a maximum benefit at low density
	sim.subpopulations.fitnessScaling = min(Ne / sim.subpopulations.individualCount, 1.5);
}

//makes the direct fitness effect of m1 mutations neutral (QTL mutations on fitness is indirect)
mutationEffect(m1)
{
	return 1.0;
}

late()
{
	for (pop in sim.subpopulations)
		if (pop.individualCount == 0)
		{
			// stop at extinction
			catn(sim.cycle + " Pop: " + pop.id + "  Extinction in cycle " + sim.cycle + ".");
		
		}
	else
	{
		// output the phenotypic mean and pop size
		phenotypes = pop.individuals.tagF;
		cat(sim.cycle + " Pop: " + pop.id + "|" + pop.individualCount + " individuals");
		cat(", phenotype mean " + mean(phenotypes));
		if (size(phenotypes) > 1)
			cat(" (sd " + sd(phenotypes) + ")");
		catn();
	}
	
	if (sum(sim.subpopulations.individualCount) == 0)
	{
		catn("GLOBAL EXTINCTION at cycle " + sim.cycle);
		sim.simulationFinished();
	}
}

20000 late()
{
	sim.simulationFinished();
}