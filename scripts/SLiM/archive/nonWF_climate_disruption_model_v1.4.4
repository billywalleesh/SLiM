/// evolutionary rescue model with multiple subpopulations
/// nonWF QTL adaptation model with environmental change


initialize()
{
	// use nonWF model
	initializeSLiMModelType("nonWF");
	// demographic parameters
	defineConstant("Ne", 500);     // carrying capacity per subpopulation
	defineConstant("N", 2);        // number of subpopulations
	//defineConstant("m", 0.01);     // migration rate
	//defineConstant("e", 0.1);      // extinction rate (future use)
	
	// environmental optima
	defineConstant("opt_1", 1.0);   // optimum before environmental change
	defineConstant("opt_2", 0.0);   // optimum before environmental change
	defineConstant("opt_delta_1", 10.0);  // optimum a after environmental change
	defineConstant("opt_delta_2", -10.0);  // optimum b after environmental change
	
	// timing of environmental shift
	defineConstant("Tdelta", 10000);
	
	// QTL mutations
	// effects drawn from N(0,1)
	initializeMutationType("m1", 0.5, "n", 0.0, 1.0);
	
	// optional neutral mutation type
	//initializeMutationType("m0", 0.5, "f", 0.0);
	
	// genomic structure
	initializeGenomicElementType("g1", m1, 1.0);
	initializeGenomicElement(g1, 0, 99999);
	
	/** alternative mixed genome structure */
	/*
	initializeGenomicElementType("g2", c(m0, m1), c(0.9, 0.1));
	initializeGenomicElement(g1, 0, 20000);
	initializeGenomicElement(g2, 20001, 30000);
	initializeGenomicElement(g1, 30001, 99999);
	*/
	
	// mutation + recombination rates
	initializeMutationRate(1e-7);
	initializeRecombinationRate(1e-8);
}

/// create subpopulations

1 early()
{
	// create N populations with Ne individuals each
	for (i in 1:N)
		sim.addSubpop(i, Ne);
	
	// set local optimum
	p1.setValue("optimum", opt_1);
	p2.setValue("optimum", opt_2);
}

/// reproduction
reproduction()
{
	if (subpop.individualCount == 0)
		return;
	//keeping reproduction within pops seperate 
	subpop.addCrossed(individual, subpop.sampleIndividuals(1));
}

