/// phenotype + fitness calculation
early()
{
	// environmental change
	if (sim.cycle == Tdelta)
	{
		p1.setValue("optimum", opt_delta_1);
		p2.setValue("optimum", opt_delta_2);
	}
	
	//calculate fitness selection
	for (pop in sim.subpopulations)
	{
		//get current optimum
		optimum = pop.getValue("optimum");
		
		// get individuals according to population
		inds = pop.individuals;
		
		// phenotype = additive sum of QTL effects
		phenotypes = inds.sumOfMutationsOfType(m1);
		
		// distance from optimum
		deviations = optimum - phenotypes;
		
		// normalize Gaussian fitness function
		fitnessFunctionMax = dnorm(0.0, 0.0, 5.0);
		
		// calculate degree of adaptation
		adaptation = dnorm(deviations, 0.0, 5.0) / fitnessFunctionMax;
		
		// convert adaptation into fitness
		//
		// perfectly adapted individual:
		// fitnessScaling = 1.0
		//
		// maladapted individual:
		// fitnessScaling approaches 0.1
		inds.fitnessScaling = 0.1 + adaptation * 0.9;
		
		// store phenotype values for output
		inds.tagF = phenotypes;
		
		// density-dependent population regulation
		//
		// low-density populations receive a fitness boost
		// capped at 1.5 to avoid unrealistic growth
		pop.fitnessScaling =
			min(Ne / pop.individualCount, 1.5);
	}
}

/// mutation effects

// QTL mutations are directly neutral
// fitness effects occur indirectly through phenotype
mutationEffect(m1) {return 1.0;}

/// output + extinction checks
late()
{
	for (pop in sim.subpopulations)
	{
		// local extinction
		if (pop.individualCount == 0)
		{
			catn(sim.cycle +
				" | Pop " + pop.id +
				" | EXTINCT");
		}
		
		// output population summary
		else
		{phenotypes = pop.individuals.tagF;
			cat(sim.cycle +
				" | Pop " + pop.id +
				" | N = " + pop.individualCount);
			cat(" | phenotype mean = " + mean(phenotypes));
			if (size(phenotypes) > 1)
				cat(" (sd = " + sd(phenotypes) + ")");
			catn();
		}
	}
	
	// global extinction
	extinctPops = sum(sim.subpopulations.individualCount == 0);
	catn("Extinct populations: " + extinctPops);
	if (sum(sim.subpopulations.individualCount) == 0)
	{
		catn("GLOBAL EXTINCTION at cycle " + sim.cycle);
		sim.simulationFinished();
	}
}

/// end simulation
20000 late(){sim.simulationFinished();}